<?xml version="1.0" encoding="utf-8"?>
<!--
  MonsterASP / IIS: use the host's dotnet runtime (avoids Deci.Api.exe — often blocked by policy 0x800704ec).
  Requires .NET 8 ASP.NET Core Runtime on the server (MonsterASP "ASP.NET Core" / Scripting panel).
  If this fails, ask support for the full path to dotnet.exe and set processPath to that value in quotes.
  Alternate (self-contained): processPath=".\Deci.Api.exe" with no arguments — only if host allows your .exe.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\Deci.Api.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="outofprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_URLS" value="http://localhost:0" />
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="DOTNET_RUNNING_IN_CONTAINER" value="false" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
