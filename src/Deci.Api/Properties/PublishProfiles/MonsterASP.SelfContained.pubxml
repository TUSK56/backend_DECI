<?xml version="1.0" encoding="utf-8"?>
<!--
  Only if your host allows running YOUR .exe (not blocked by 0x800704ec).
  After publish, replace web.config aspNetCore with processPath=".\Deci.Api.exe" and remove arguments.
  win-x64: dotnet publish ... -p:PublishProfile=MonsterASP.SelfContained -o ./publish
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>$(MSBuildProjectDirectory)\bin\Release\net8.0\win-x64\publish\</PublishDir>
  </PropertyGroup>
</Project>
