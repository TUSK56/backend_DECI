<?xml version="1.0" encoding="utf-8"?>
<!--
  MonsterASP.NET (recommended): framework-dependent — no Deci.Api.exe, no coreclr in publish.
  Host must have .NET 8 ASP.NET Core Runtime. web.config uses: dotnet .\Deci.Api.dll

  From backend folder:
    dotnet publish src/Deci.Api/Deci.Api.csproj -c Release -p:PublishProfile=MonsterASP -o ./publish
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>$(MSBuildProjectDirectory)\bin\Release\net8.0\publish\</PublishDir>
  </PropertyGroup>
</Project>
